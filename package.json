{
  "name": "customer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --allowed-hosts",
    "build": "node tools/set-env.js && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:customer": "node dist/customer/server/server.mjs",
    "build:mobile": "ng build --configuration mobile && cp dist/customer/browser/index.csr.html dist/customer/browser/index.html",
    "cap:sync": "npx cap sync",
    "apk": "npm run build:mobile && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "private": true,
  "packageManager": "npm@^11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-server": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/ssr": "^21.2.7",
    "@capacitor/android": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/status-bar": "^8.0.2",
    "@lucide/angular": "^1.16.0",
    "express": "^5.1.0",
    "html2pdf.js": "^0.14.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.7",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
